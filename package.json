{
  "name": "@otg-dev/seedforge",
  "version": "2.2.0",
  "description": "Generate realistic seed data from your database schema",
  "type": "module",
  "bin": {
    "seedforge": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run --exclude 'src/__tests__/e2e/**'",
    "test:watch": "vitest",
    "test:e2e": "vitest run --testTimeout 120000 src/__tests__/e2e/",
    "test:all": "vitest run --testTimeout 120000",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "seed",
    "database",
    "postgresql",
    "faker",
    "test-data",
    "schema",
    "cli",
    "data-generation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "mysql2": "^3.20.0",
    "pg": "^8.20.0",
    "pg-copy-streams": "^7.0.0",
    "pg-format": "^1.0.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/pg-format": "^1.0.5",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "testcontainers": "^11.13.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
